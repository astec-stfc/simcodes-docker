FROM almalinux/9-minimal

ENTRYPOINT ["/bin/bash"]
WORKDIR /simcodes

# Requirements
RUN microdnf install wget dnf -y && microdnf clean all


# ASTRA (single code and parallel)
RUN mkdir Astra-serial &&\
    cd Astra-serial &&\
    wget https://www.desy.de/~mpyflo/Astra_for_64_Bit_Linux/Astra && \
    wget https://www.desy.de/~mpyflo/Astra_for_64_Bit_Linux/generator && \
    chmod +x Astra generator

RUN mkdir Astra-parallel && \
    cd Astra-parallel && \
    wget https://www.desy.de/~mpyflo/Parallel_Astra_for_Linux/Astra && \
    chmod +x Astra Astra

# CSRTRack

RUN mkdir CSRTrack-serial && \
    cd CSRTrack-serial && \ 
    wget https://www.desy.de/xfel-beam/csrtrack/files/csrtrack_1.204_Linux_x86_64_serial

RUN mkdir CSRTrack-parallel && \
    cd CSRTrack-parallel && \
    wget https://www.desy.de/xfel-beam/csrtrack/files/csrtrack_1.204_Linux_x86_64_OpenMPI_1.4.3

# Elegant
RUN dnf install git gsl-devel fftw-devel lapack blas gfortran mpich mpich-devel -y && \
    dnf group install "Development Tools" -y

RUN git clone https://github.com/rtsoliday/SDDS.git

RUN ln -s /lib64/libblas.so.3 /lib64/libblas.so &&\
    ln -s /lib64/liblapack.so.3 /lib64/liblapack.so 

RUN git clone https://github.com/rtsoliday/elegant.git &&\
    cd elegant &&\
    git checkout elegant-2026.1.0 &&\
    export MPI_PATH=/usr/lib64/mpich && \
    export USE_MPI=1 &&\
    make

ENV RPN_DEFNS=/elegant/SDDS/defns.rpn


